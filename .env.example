# Sign up at https://api.congress.gov/sign-up — key arrives by email, ~instant
CONGRESS_GOV_API_KEY=

# Sign up at https://api.govinfo.gov/docs (click "Get API Key") — instant signup via api.data.gov
GOVINFO_API_KEY=

# For the chat REPL (scripts/chat.py). Get at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Auth (web login) -------------------------------------------------
# JWT signing secret for user sessions. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If left blank, the server generates one on first run and persists it
# at data/auth_secret.key. Set it explicitly in production.
POLILABS_JWT_SECRET=

# Where the user-accounts SQLite DB lives (optional; defaults to data/auth.db).
# POLILABS_AUTH_DB=data/auth.db
